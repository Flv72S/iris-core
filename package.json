{
  "name": "iris-messaging-ui",
  "version": "0.1.0",
  "private": true,
  "description": "IRIS Messaging Core UI — Proiezione Passiva",
  "type": "module",
  "bin": {
    "iris-audit-validate": "./bin/iris-audit-validate.mjs"
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "audit:validate": "tsx src/logging/cli/audit.ts",
    "test:watch": "vitest",
    "test:ui": "vitest run src/ui/tests",
    "test:explainability": "vitest run phase-10-explainability --bail=1",
    "iris:node1": "tsx scripts/run_node.ts --port=3001 --peers=3002,3003 --nodeId=node-3001 --storagePath=.iris-node-3001",
    "iris:node2": "tsx scripts/run_node.ts --port=3002 --peers=3001,3003 --nodeId=node-3002 --storagePath=.iris-node-3002",
    "iris:node3": "tsx scripts/run_node.ts --port=3003 --peers=3001,3002 --nodeId=node-3003 --storagePath=.iris-node-3003",
    "iris:send": "tsx scripts/send_decision.ts",
    "iris:storm": "tsx scripts/storm_test.ts",
    "iris:partition": "tsx scripts/partition_simulator.ts",
    "iris:check": "tsx scripts/check_convergence.ts",
    "iris:crash-test:v2": "tsx scripts/runtime_crash_test_v2.ts",
    "iris:byzantine": "tsx scripts/runtime_byzantine_test.ts",
    "test:certify:cluster": "vitest run tests/runtime/certify_cluster.test.ts tests/runtime/deterministic_ordering.test.ts tests/runtime/byzantine_boundary.test.ts",
    "test:determinism:hardening": "vitest run tests/runtime/determinism_hardening.test.ts",
    "test:determinism:hardening:with-cert": "vitest run tests/runtime/determinism_hardening.test.ts tests/runtime/certify_cluster.test.ts",
    "determinism:docker": "docker build -t iris-determinism-test . && docker run --rm iris-determinism-test",
    "architecture-check": "tsx scripts/architecture-check.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "build": "tsc --noEmit && echo 'Build check passed'",
    "prisma:generate:threads": "prisma generate --schema prisma/schema.prisma",
    "postinstall": "npm run prisma:generate:threads"
  },
  "dependencies": {
    "@prisma/client": "^6.16.1",
    "better-sqlite3": "^9.2.0",
    "fastify": "^4.24.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^8.50.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "glob": "^10.3.0",
    "jsdom": "^23.0.0",
    "prettier": "^3.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.7.0",
    "typescript": "^5.2.0",
    "vite": "^7.3.1",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0 <21"
  }
}
