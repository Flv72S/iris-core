# IRIS - Development Environment Configuration
# Copy this file to .env and adjust values as needed

# HTTP Server Configuration
HTTP_PORT=3000

# Persistence Configuration
# Options: 'memory' | 'sqlite'
PERSISTENCE=memory

# SQLite Configuration (required if PERSISTENCE=sqlite)
SQLITE_FILE_PATH=./data/iris.db

# Logging Configuration
# Options: 'debug' | 'info' | 'warn' | 'error'
LOG_LEVEL=info

# Graceful Shutdown Configuration
# Timeout in milliseconds for graceful shutdown
SHUTDOWN_TIMEOUT_MS=10000

# Preview Mode Configuration (STEP 6B)
# Enable preview mode (true|false)
PREVIEW_MODE=false
# Access token for preview (required if PREVIEW_MODE=true)
PREVIEW_ACCESS_TOKEN=
# Rate limit per minute per IP (default: 60)
PREVIEW_RATE_LIMIT_RPM=60

# Feature Flags (STEP 6C) - fail-closed
# Allowed values: true | false
FEATURE_THREADS_ENABLED=true
FEATURE_SYNC_ENABLED=true

# Preview Mode Configuration (STEP 6B)
# Enable preview mode (true|false)
PREVIEW_MODE=false
# Access token for preview (required if PREVIEW_MODE=true)
PREVIEW_ACCESS_TOKEN=
# Rate limit per minute per IP (default: 60)
PREVIEW_RATE_LIMIT_RPM=60
