generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Thread {
  id        String    @id
  title     String
  archived  Boolean
  createdAt DateTime
  updatedAt DateTime
  messages  Message[]
}

model Message {
  id        String   @id
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id])
  author    String
  content   String
  createdAt DateTime
}

